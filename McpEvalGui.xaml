<UserControl x:Class="McpEval.McpEvalGui"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:McpEval"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="400">
    <Grid DataContext="{x:Static local:McpEvalSettings.Instance}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Server Toggle -->
        <Label Grid.Row="0" Grid.Column="0" Content="Server Enabled:" VerticalAlignment="Center" />
        <CheckBox Grid.Row="0" Grid.Column="2" x:Name="CheckBoxEnabled"
                  IsChecked="{Binding Path=ServerEnabled, Mode=TwoWay}"
                  VerticalAlignment="Center"
                  Checked="CheckBoxEnabled_Changed"
                  Unchecked="CheckBoxEnabled_Changed" />

        <!-- Port -->
        <Label Grid.Row="2" Grid.Column="0" Content="Port:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="2" x:Name="TextBoxPort"
                 Text="{Binding Path=Port, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                 VerticalAlignment="Center" Width="80" HorizontalAlignment="Left" />

        <!-- Apply Button -->
        <Button Grid.Row="4" Grid.Column="2" x:Name="ButtonApply"
                Content="Restart Server" Width="100" HorizontalAlignment="Left"
                Click="ButtonApply_Click"
                ToolTipService.ToolTip="Stop and restart the MCP server with the current port." />

        <!-- Status -->
        <Label Grid.Row="6" Grid.Column="0" Content="Status:" VerticalAlignment="Center" />
        <Label Grid.Row="6" Grid.Column="2" x:Name="LabelStatus"
               Content="Unknown" VerticalAlignment="Center" Foreground="Gray" />
    </Grid>
</UserControl>
